# Force LF on text files so Windows checkouts don't churn line endings
# on Capacitor-generated files (capacitor.build.gradle, capacitor.settings.gradle, AndroidManifest.xml, etc.)
*.gradle   text eol=lf
*.xml      text eol=lf
*.java     text eol=lf
*.kt       text eol=lf
*.pro      text eol=lf
*.properties text eol=lf
gradlew    text eol=lf

# Windows-only script must stay CRLF
*.bat      text eol=crlf

# Binary assets — never touch
*.png      binary
*.jpg      binary
*.jpeg     binary
*.webp     binary
*.jar      binary
*.keystore binary
*.jks      binary
