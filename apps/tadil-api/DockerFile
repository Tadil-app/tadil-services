FROM node:22-alpine AS deps
WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm install --legacy-peer-deps

COPY libs/infra/tadil-database/package.json libs/infra/tadil-database/
RUN cd libs/infra/tadil-database && npm install --legacy-peer-deps

COPY libs/infra/file-storage/package.json libs/infra/file-storage/
RUN cd libs/infra/file-storage && npm install --legacy-peer-deps

FROM node:22-alpine AS builder
WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm install --legacy-peer-deps

COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/libs/infra/tadil-database/node_modules ./libs/infra/tadil-database/node_modules
COPY --from=deps /app/libs/infra/file-storage/node_modules ./libs/infra/file-storage/node_modules

COPY . .

RUN npm run db-generate
RUN npx nx build tadil-api --prod

FROM node:22-alpine AS runner
WORKDIR /app

COPY --from=builder /app/dist/apps/tadil-api ./dist/apps/tadil-api

COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/libs/infra/tadil-database/node_modules ./libs/infra/tadil-database/node_modules
COPY --from=builder /app/libs/infra/file-storage/node_modules ./libs/infra/file-storage/node_modules

COPY libs/infra/tadil-database/prisma ./libs/infra/tadil-database/prisma

ENV NODE_ENV=production
ENV PORT=4444

EXPOSE 4444

CMD ["sh", "-c", "npm run db-migrate-deploy && node dist/apps/tadil-api/main.js"]

