# -----------------------------------------------------------------
# STAGE 1: Build & Compile the NestJS Application
# -----------------------------------------------------------------
FROM node:20-alpine AS builder

WORKDIR /usr/src/app

# Copy package.json and package-lock.json
COPY package*.json ./

# Install all dependencies (including devDependencies needed for 'nest build')
RUN npm ci

# Copy all source files
COPY . .

# Compile TypeScript into JavaScript (output is usually 'dist')
RUN npm run build

# -----------------------------------------------------------------
# STAGE 2: Production Runtime
# -----------------------------------------------------------------
FROM node:20-alpine AS production

# Set environment variable for production optimization
ENV NODE_ENV production

WORKDIR /usr/src/app

# Copy only production dependencies from the build stage 
# (This excludes dev dependencies like Nest CLI, Jest, etc.)
COPY --from=builder /usr/src/app/package*.json ./
# Run npm ci to get only production dependencies in the final image
# This is a key step to reduce image size!
RUN npm ci --only=production

# Copy the compiled application code (the 'dist' folder)
COPY --from=builder /usr/src/app/dist ./dist

# Set a non-root user for security (best practice)
RUN adduser -D nestjs
USER nestjs

# Expose the port your NestJS app listens on (default is 3000)
EXPOSE 4444

# Start the compiled application
# Change 3000 here if your NestJS app listens on a different port (e.g., 8080 or 4444)
CMD ["node", "dist/main"]