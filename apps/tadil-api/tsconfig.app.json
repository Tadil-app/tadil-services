{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "types": ["node"],
    "rootDir": "src",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "es2021"
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "out-tsc",
    "dist",
    "jest.config.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "eslint.config.js",
    "eslint.config.cjs",
    "eslint.config.mjs"
  ],
  "references": [
    {
      "path": "../../libs/core/tadil-models/tsconfig.lib.json"
    },
    {
      "path": "../../libs/core/tadil-informations/tsconfig.lib.json"
    },
    {
      "path": "../../libs/core/tadil-common/tsconfig.lib.json"
    },
    {
      "path": "../../libs/core/tadil-services/tsconfig.lib.json"
    },
    {
      "path": "../../libs/infra/tadil-database/tsconfig.lib.json"
    },
    {
      "path": "../../libs/infra/file-storage/tsconfig.lib.json"
    }
  ]
}
