name: Build iOS for BrowserStack

on:
  push:
    branches: [ ios ] # Triggers whenever you push code to your ios branch

jobs:
  build-and-upload:
    runs-on: macos-latest # Uses GitHub's hosted Mac environment

    steps:
      - name: Checkout Repository
        uses: actions/checkout@v4

      - name: Set up Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '22' # Fixed key name and pinned to stable LTS for mobile builds
          cache: 'npm'

      - name: Install Dependencies
        run: npm ci # Uses package-lock.json for clean installations

      # Step 3: Injects your custom Vue environment variables securely
      - name: Build Web Assets (Vue)
        run: npm run build
        env:
          VITE_TADIL_MOBILE_API_URL: ${{ secrets.VITE_TADIL_MOBILE_API_URL }}
          VITE_MOYASAR_PUBLISHABLE_KEY: ${{ secrets.VITE_MOYASAR_PUBLISHABLE_KEY }}

      - name: Sync Capacitor to iOS Platform
        run: |
          npx cap sync ios

      # Step 4: Compiles an unsigned build, passing a clean local output directory flag
      - name: Build Xcode Project (Simulator Architecture)
        run: |
          xcodebuild build \
            -workspace ios/App/App.xcworkspace \
            -scheme App \
            -sdk iphonesimulator \
            -configuration Debug \
            -derivedDataPath ios-build-data \
            CODE_SIGNING_ALLOWED=NO \
            CODE_SIGNING_REQUIRED=NO \
            CODE_SIGNING_IDENTITY=""

      # Step 5: Packaging the bundle reliably from the custom derivedDataPath location
      - name: Package App for BrowserStack
        run: |
          mkdir -p build-output
          # Safely copy the compiled simulator package directly from our custom path
          cp -r ios-build-data/Build/Products/Debug-iphonesimulator/App.app build-output/
          cd build-output
          zip -r ios-simulator-app.zip App.app

      # Step 6: Upload directly into BrowserStack Account via API curl
      - name: Upload Application to BrowserStack App Live
        id: upload
        run: |
          RESPONSE=$(curl -u "${{ secrets.BROWSERSTACK_USERNAME }}:${{ secrets.BROWSERSTACK_ACCESS_KEY }}" \
            -X POST "https://api-cloud.browserstack.com/app-automate/upload" \
            -F "file=@build-output/ios-simulator-app.zip" \
            -F "custom_id=IonicVueDevApp")
          
          echo "BrowserStack Upload Response: $RESPONSE"
