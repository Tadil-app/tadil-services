{
  "compilerOptions": {
    "rootDir": ".",
    "baseUrl": ".",
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "node",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "paths": {
      "@tadil-database": ["libs/infra/tadil-database/src/index.ts"],
      "@file-storage": ["libs/infra/file-storage/src/index.ts"],
      "@tadil-common": ["libs/core/tadil-common/src/index.ts"],
      "@tadil-informations": ["libs/core/tadil-informations/src/index.ts"],
      "@tadil-models": ["libs/core/tadil-models/src/index.ts"],
      "@tadil-alterations": ["libs/core/tadil-alterations/src/index.ts"],
      "@tadil-extras": ["libs/core/tadil-extras/src/index.ts"],
      "@tadil-tailor": ["libs/core/tadil-tailor/src/index.ts"],
      "@tadil-users": ["libs/core/tadil-users/src/index.ts"]
    }
  }
}
