generator client {
    provider = "prisma-client-js"
}

generator json {
    provider = "prisma-json-types-generator"
}

datasource db {
    provider = "postgresql"
    url      = env("TADIL_DB")
}

model Section {
    id          String @id @default(uuid())
    englishName String
    arabicName  String
    urduName    String
    hindiName   String
    bengaliName String
    /// ![{x: number; y:number}]
    coordinates Json[]

    services     Alteration[] @relation("alterations-sections")
    modelImageId String
    image        ModelImage   @relation(fields: [modelImageId], references: [id], onDelete: Cascade)

    @@map("sections")
}

model ModelImage {
    id     String @id @default(uuid())
    fileId String

    modelId  String
    model    Model     @relation(fields: [modelId], references: [id], onDelete: Cascade)
    sections Section[]

    @@map("models-images")
}

model Model {
    id          String        @id @default(uuid())
    englishName String
    arabicName  String
    urduName    String
    hindiName   String
    bengaliName String
    category    ModelCategory @default(all)
    images      ModelImage[]

    @@map("models")
}

model Information {
    id          String          @id @default(uuid())
    englishName String
    arabicName  String
    urduName    String
    hindiName   String
    bengaliName String
    isRequired  Boolean         @default(false)
    type        InformationType @default(text)
    unit        String?

    services                        Alteration[]                     @relation("alterations-informations")
    extras                          Extra[]                          @relation("informations-extras")
    orderItemAlterationInformations OrderItemAlterationInformation[]

    @@map("informations")
}

model Alteration {
    id          String @id @default(uuid())
    englishName String
    arabicName  String
    urduName    String
    hindiName   String
    bengaliName String
    price       Float

    sections             Section[]             @relation("alterations-sections")
    informations         Information[]         @relation("alterations-informations")
    orderItemAlterations OrderItemAlteration[]

    @@map("alterations")
}

model Extra {
    id          String @id @default(uuid())
    englishName String
    arabicName  String
    urduName    String
    hindiName   String
    bengaliName String
    price       Float

    informations Information[] @relation("informations-extras")

    @@map("extras")
}

enum ModelCategory {
    all
    men
    women
    kids
}

model OrderItemAlterationInformation {
    id    String @id @default(uuid())
    value String
    sourceInformationId   String
    sourceInformation     Information         @relation(fields: [sourceInformationId], references: [id])

    orderItemAlterationId String
    orderItemAlteration   OrderItemAlteration @relation(fields: [orderItemAlterationId], references: [id], onDelete: Cascade)

    @@map("order-item-alteration-informations")
}

model OrderItemAlteration {
    id           String                           @id @default(uuid())
    informations OrderItemAlterationInformation[]

    sourceAlterationId String
    sourceAlteration   Alteration @relation(fields: [sourceAlterationId], references: [id])
    

    @@map("order-item-alterations")
}

enum InformationType {
    text
    number
    select_menu
    checkbox
}

enum OrderStatus {
    pending
    inProgress
    completed
    waitingForPickup
}
