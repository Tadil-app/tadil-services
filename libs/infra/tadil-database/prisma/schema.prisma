generator client {
    provider = "prisma-client-js"
}

generator json {
    provider = "prisma-json-types-generator"
}

datasource db {
    provider = "postgresql"
    url      = env("TADIL_DB")
}

enum ModelCategory {
    all
    men
    women
    kids
}

enum InformationType {
    text
    number
    select_menu
    checkbox
}

enum OrderStatus {
    pending
    waitingForTailorAssignement
    waitingForCourierAssignement
    waitingForPickupFromCustomer
    waitingForDropoffToTailor
    inProgress
    waitingForReturnCourierAssignement
    waitingForPickupFromTailor
    waitingForDropoffToCustomer
    done
}

enum LoginRequestStatus {
    PENDING
    APPROVED
    REJECTED
}

enum Role {
    tailor
    customer
    courier
}

enum TransactionType {
    EARNING
    PAYOUT
}

enum PayoutStatus {
    PENDING
    FULFILLED
    REJECTED
}

model Section {
    id          String @id @default(uuid())
    englishName String
    arabicName  String
    urduName    String
    hindiName   String
    bengaliName String
    /// ![{x: number; y:number}]
    coordinates Json[]

    services     Alteration[] @relation("alterations-sections")
    modelImageId String
    image        ModelImage   @relation(fields: [modelImageId], references: [id], onDelete: Cascade)

    @@map("sections")
}

model ModelImage {
    id     String @id @default(uuid())
    fileId String

    modelId  String
    model    Model     @relation(fields: [modelId], references: [id], onDelete: Cascade)
    sections Section[]

    @@map("models-images")
}

model Model {
    id          String        @id @default(uuid())
    englishName String
    arabicName  String
    urduName    String
    hindiName   String
    bengaliName String
    category    ModelCategory @default(all)
    images      ModelImage[]

    @@map("models")
}

model Information {
    id          String          @id @default(uuid())
    englishName String
    arabicName  String
    urduName    String
    hindiName   String
    bengaliName String
    isRequired  Boolean         @default(false)
    type        InformationType @default(text)
    unit        String?

    services Alteration[] @relation("alterations-informations")
    extras   Extra[]      @relation("informations-extras")

    @@map("informations")
}

model Alteration {
    id          String @id @default(uuid())
    englishName String
    arabicName  String
    urduName    String
    hindiName   String
    bengaliName String
    price       Float

    sections     Section[]     @relation("alterations-sections")
    informations Information[] @relation("alterations-informations")

    @@map("alterations")
}

model Extra {
    id          String @id @default(uuid())
    englishName String
    arabicName  String
    urduName    String
    hindiName   String
    bengaliName String
    price       Float

    informations Information[] @relation("informations-extras")

    @@map("extras")
}

model OrderItemAlterationInformation {
    id          String          @id @default(uuid())
    englishName String
    arabicName  String
    urduName    String
    hindiName   String
    bengaliName String
    type        InformationType
    unit        String?
    value       String

    orderItemAlterationId String
    orderItemAlteration   OrderItemAlteration @relation(fields: [orderItemAlterationId], references: [id], onDelete: Cascade)

    @@map("order-item-alteration-informations")
}

model OrderItemAlteration {
    id                String @id @default(uuid())
    englishName       String
    arabicName        String
    urduName          String
    hindiName         String
    bengaliName       String
    price             Float
    /// ![{x: number; y:number}]
    customCoordinates Json[]

    informations       OrderItemAlterationInformation[]
    orderItemSectionId String?
    orderItemSection   OrderItemSection?                @relation(fields: [orderItemSectionId], references: [id], onDelete: Cascade)
    customOrderItemId  String?
    customOrderItem    CustomOrderItem?                 @relation(fields: [customOrderItemId], references: [id], onDelete: Cascade)

    @@map("order-item-alterations")
}

model OrderItemSection {
    id          String @id @default(uuid())
    englishName String
    arabicName  String
    urduName    String
    hindiName   String
    bengaliName String
    /// ![{x: number; y:number}]
    coordinates Json[]
    imageFileId String

    alterations OrderItemAlteration[]
    orderItemId String
    orderItem   OrderItem             @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

    @@map("order-item-sections")
}

model OrderItem {
    id          String @id @default(uuid())
    price       Float  @default(0)
    englishName String
    arabicName  String
    urduName    String
    hindiName   String
    bengaliName String
    imageFileId String

    sections OrderItemSection[]
    orderId  String
    order    Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)

    @@map("order-items")
}

model CustomOrderItem {
    id          String @id @default(uuid())
    price       Float  @default(0)
    imageFileId String

    alterations OrderItemAlteration[]
    orderId     String
    order       Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)

    @@map("custom-order-items")
}

model Order {
    id         String      @id @default(uuid())
    reference  String      @unique()
    date       DateTime    @default(now())
    totalPrice Float       @default(0)
    status     OrderStatus

    items       OrderItem[]
    customItems CustomOrderItem[]

    customerId String
    customer   User   @relation("customer-orders", fields: [customerId], references: [id], onDelete: Cascade)

    addressId String?
    address   Address? @relation(fields: [addressId], references: [id])

    assignedTailorId String?
    assignedTailor   User?   @relation("user-assigned-order", fields: [assignedTailorId], references: [id], onDelete: Cascade)
    rejectedTailors  User[]  @relation("user-rejected-orders")

    assignedCourierId String?
    assignedCourier   User?   @relation("courier-assigned-order", fields: [assignedCourierId], references: [id], onDelete: Cascade)
    rejectedCouriers  User[]  @relation("courier-rejected-orders")

    assignedReturnCourierId String?
    assignedReturnCourier   User?   @relation("return-courier-assigned-order", fields: [assignedReturnCourierId], references: [id], onDelete: Cascade)
    rejectedReturnCouriers  User[]  @relation("return-courier-rejected-orders")

    history OrderStatusHistory[]

    @@map("orders")
}

model OrderStatusHistory {
    id        String      @id @default(uuid())
    orderId   String
    order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
    status    OrderStatus
    timestamp DateTime    @default(now())

    @@map("order-status-histories")
}

model Address {
    id       String  @id @default(uuid())
    city     String
    street   String?
    district String?
    userId   String
    user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

    orders Order[]

    @@map("addresses")
}

model User {
    id        String  @id @default(uuid())
    phone     String  @unique
    firstName String
    lastName  String
    email     String?
    role      Role

    loginRequestStatus LoginRequestStatus?
    loginToken         String?

    walletBalance  Float @default(0)
    commissionRate Float @default(10)

    addresses Address[]

    orders Order[] @relation("customer-orders")

    assignedOrders Order[] @relation("user-assigned-order")
    rejectedOrders Order[] @relation("user-rejected-orders")

    assignedCouriers Order[] @relation("courier-assigned-order")
    rejectedCouriers Order[] @relation("courier-rejected-orders")

    assignedReturnOrders Order[] @relation("return-courier-assigned-order")
    rejectedReturnOrders Order[] @relation("return-courier-rejected-orders")

    transactions   Transaction[]
    payoutRequests PayoutRequest[]

    @@map("users")
}

model Transaction {
    id        String          @id @default(uuid())
    reference String          @unique
    amount    Float
    type      TransactionType
    date      DateTime        @default(now())

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    orderId String?

    @@map("transactions")
}

model PayoutRequest {
    id     String       @id @default(uuid())
    amount Float
    status PayoutStatus @default(PENDING)
    date   DateTime     @default(now())

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("payout-requests")
}
