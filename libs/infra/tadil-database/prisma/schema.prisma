generator client {
    provider = "prisma-client-js"
}

generator json {
    provider = "prisma-json-types-generator"
}

datasource db {
    provider = "postgresql"
    url      = env("TADIL_DB")
}

model Section {
    id          String @id @default(uuid())
    englishName String
    arabicName  String
    urduName    String
    hindiName   String
    bengaliName String
    /// ![{x: number; y:number}]
    coordinates Json[]

    services     Alteration[] @relation("alterations-sections")
    modelImageId String
    image        ModelImage   @relation(fields: [modelImageId], references: [id], onDelete: Cascade)

    @@map("sections")
}

model ModelImage {
    id     String @id @default(uuid())
    fileId String

    modelId  String
    model    Model     @relation(fields: [modelId], references: [id], onDelete: Cascade)
    sections Section[]

    @@map("models-images")
}

model Model {
    id          String       @id @default(uuid())
    englishName String
    arabicName  String
    urduName    String
    hindiName   String
    bengaliName String
    images      ModelImage[]

    @@map("models")
}

model Information {
    id          String  @id @default(uuid())
    englishName String
    arabicName  String
    urduName    String
    hindiName   String
    bengaliName String
    value       String?
    unit        String?

    services Alteration[] @relation("alterations-informations")

    @@map("informations")
}

model Alteration {
    id          String @id @default(uuid())
    englishName String
    arabicName  String
    urduName    String
    hindiName   String
    bengaliName String
    price       Float

    sections     Section[]     @relation("alterations-sections")
    informations Information[] @relation("alterations-informations")

    @@map("alterations")
}
