generator client {
    provider = "prisma-client-js"
}

generator json {
    provider = "prisma-json-types-generator"
}

datasource db {
    provider = "postgresql"
    url      = env("TADIL_DB")
}

model Section {
    id          String @id @default(uuid())
    englishName String
    arabicName  String
    urduName    String
    hindiName   String
    bengaliName String
    /// ![{x: number; y:number}]
    coordinates Json[]

    modelId  String
    models   Model     @relation(fields: [modelId], references: [id], onDelete: Cascade)
    services Service[] @relation("services-sections")

    @@map("sections")
}

model Model {
    id          String    @id @default(uuid())
    imageFileId String
    englishName String
    arabicName  String
    urduName    String
    hindiName   String
    bengaliName String
    sections    Section[]

    @@map("models")
}

model Information {
    id          String  @id @default(uuid())
    englishName String
    arabicName  String
    urduName    String
    hindiName   String
    bengaliName String
    value       String?
    unit        String?

    services Service[] @relation("services-informations")

    @@map("informations")
}

model Service {
    id          String @id @default(uuid())
    englishName String
    arabicName  String
    urduName    String
    hindiName   String
    bengaliName String
    price       Float

    sections    Section[]     @relation("services-sections")
    alterations Information[] @relation("services-informations")

    @@map("services")
}
