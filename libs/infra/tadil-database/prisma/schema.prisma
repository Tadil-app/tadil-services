generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("TADIL_DB")
}

model Section {
    id          String @id @default(uuid())
    englishName String
    arabicName  String
    urduName    String
    hindiName   String
    bengaliName String

    @@map("sections")
}
