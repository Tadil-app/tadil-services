generator client {
    provider = "prisma-client-js"
}

generator json {
    provider = "prisma-json-types-generator"
}

datasource db {
    provider = "postgresql"
    url      = env("TADIL_DB")
}

model Section {
    id          String @id @default(uuid())
    englishName String
    arabicName  String
    urduName    String
    hindiName   String
    bengaliName String
    /// ![{x: number; y:number}]
    coordinates Json[]

    modelId  String
    models   Model        @relation(fields: [modelId], references: [id], onDelete: Cascade)
    services Alteration[] @relation("alterations-sections")

    @@map("sections")
}

model Model {
    id          String    @id @default(uuid())
    imageFileId String
    englishName String
    arabicName  String
    urduName    String
    hindiName   String
    bengaliName String
    sections    Section[]

    @@map("models")
}

model Information {
    id          String  @id @default(uuid())
    englishName String
    arabicName  String
    urduName    String
    hindiName   String
    bengaliName String
    value       String?
    unit        String?

    services Alteration[] @relation("alterations-informations")

    @@map("informations")
}

model Alteration {
    id          String @id @default(uuid())
    englishName String
    arabicName  String
    urduName    String
    hindiName   String
    bengaliName String
    price       Float

    sections     Section[]     @relation("alterations-sections")
    informations Information[] @relation("alterations-informations")

    @@map("alterations")
}
